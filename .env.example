# Copy to .env.local for local dev (and add the same two vars in your host).
# Online Sing-Off is optional — without these, Practice and same-device
# Sing-Off still work fully. Find these in your Supabase project: Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
